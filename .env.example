# ─── Development (local Docker Compose) ─────────────────────────────
# Copy to `.env` at the repo root (gitignored):
#   cp .env.example .env
#
# Consumer: `docker compose up` / `compose.yaml`
# Database: tador_dev (never staging/production secrets here)
#
# Host Prisma / Vitest use other files:
#   backend/.env.example → backend/.env
#   backend/.env.test.example → backend/.env.test
#
# Staging VPS (HAProxy): see `.env.staging.example`
# Production deploy:     see `.env.production.example`

POSTGRES_DB=tador_dev
POSTGRES_USER=tador
POSTGRES_PASSWORD=tador_dev_password
POSTGRES_PORT=5432

# Optional: force DB host. If omitted, auto-detects:
#   /.dockerenv present → postgres
#   otherwise → localhost
# Compose always sets POSTGRES_HOST=postgres for the backend service.
# That MUST win over a mounted backend/.env DATABASE_URL=@localhost
# (containers cannot reach Postgres via localhost).
# POSTGRES_HOST=localhost

SESSION_SECRET=change-me-in-production-local-only

# Browser origins allowed with credentials (SPA + Vite in Compose).
CORS_ORIGIN=http://localhost:5173,http://frontend:5173

# Optional published ports (Compose interpolation).
# BACKEND_PORT=3000
# FRONTEND_PORT=5173

# Backend listen (Compose sets these on the backend service by default).
# PORT=3000
# HOST=0.0.0.0
# LOG_LEVEL=info

# Path routing is for staging nginx only (see docs/deploy-path-routing.md).
# Local compose publishes ports directly — no gateway.
# FRONTEND_BASE_PATH=/          # default in compose
# ADMIN_UI_BASE_PATH=/
# CORS_ORIGIN=http://localhost:5173,http://frontend:5173

# Admin platform (013) — see specs/013-admin-platform/auth-bootstrap.md
DEPLOYMENT_PROFILE=full
OPERATOR_SESSION_SECRET=change-me-admin-session
ADMIN_CORS_ORIGIN=http://localhost:5174,http://admin-ui:5174
ADMIN_INITIAL_EMAIL=admin@localhost
ADMIN_INITIAL_PASSWORD=dev-admin

# MVP: leave unset/false. Post-MVP set to "true" to enforce FR-009.
# REQUIRE_EMAIL_VERIFICATION=false

# Dev: plantillas admin tool. Default on when NODE_ENV !== production.
# ENABLE_PLANTILLAS_ADMIN=true

# Integration tests: see backend/.env.test.example (copy → backend/.env.test).
# Vitest never uses POSTGRES_DB / tador_dev for cleanup.

# Post-MVP email provider (delta 001 Follow-up D1) — not consumed yet by backend.
# EMAIL_PROVIDER=smtp
# EMAIL_FROM=noreply@tador.local
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# APP_PUBLIC_URL=http://localhost:5173
