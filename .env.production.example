# ─── Production contract (versioned template) ───────────────────────
# What this is for:
#   Final public production of TADOR (real users, real money data),
#   typically the same topology as staging (HAProxy same-origin + Docker)
#   but with production DB, domain, and secrets.
#
# What this is NOT:
#   - Local development → use `.env.example` → `.env`
#   - Staging / QA VPS  → use `.env.staging.example` → `.env.staging`
#     (or a site file like `.env.prod.nesistel` for a named staging network)
#
# How to use:
#   Copy into a secret manager or an ignored host file, e.g.:
#     cp .env.production.example .env.production
#   Inject the same keys into `compose.staging.yaml` (or a future
#   compose.production.yaml) / your orchestrator. Never commit real values.
#
# DATABASE_URL may point at managed Postgres (TLS) instead of a Compose
# `postgres` service. If you keep Postgres in Compose, mirror the staging
# shape (POSTGRES_* + DATABASE_URL@postgres).

NODE_ENV=production
HOST=0.0.0.0
PORT=3000
LOG_LEVEL=info

# Prefer the URL supplied by the managed PostgreSQL provider.
# Keep TLS enabled and use an application user with least privilege.
DATABASE_URL=postgresql://tador_app:REPLACE_WITH_DB_PASSWORD@db.example.com:5432/tador?sslmode=require

# If Postgres runs in Compose on the same host (optional alternative):
# POSTGRES_DB=tador
# POSTGRES_USER=tador_app
# POSTGRES_PASSWORD=REPLACE_WITH_DB_PASSWORD
# POSTGRES_HOST=postgres
# POSTGRES_PORT=5432

# Generate independently for each environment, for example:
# openssl rand -base64 48
SESSION_SECRET=REPLACE_WITH_AT_LEAST_32_RANDOM_BYTES

# Comma-separated HTTPS browser origins allowed to send credentials.
# With a same-origin reverse proxy, keep the public application origin here.
CORS_ORIGIN=https://app.example.com

# Production must not expose the development administration routes.
ENABLE_PLANTILLAS_ADMIN=false

# Keep disabled until a real email provider and public verification/recovery
# links replace the current email stub, which logs tokens.
REQUIRE_EMAIL_VERIFICATION=false

# Loopback publish for HAProxy (when using Compose on the VPS)
# BACKEND_HOST_PORT=3000
# FRONTEND_HOST_PORT=8080

# Optional post-MVP (backend does not consume these yet)
# APP_PUBLIC_URL=https://app.example.com
# EMAIL_PROVIDER=smtp
# EMAIL_FROM=noreply@app.example.com
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
