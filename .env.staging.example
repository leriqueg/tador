# ─── Staging contract (versioned template) ──────────────────────────
# Copy on the VPS (gitignored real file), e.g.:
#   cp .env.staging.example .env.staging
#   # or a site-specific name: .env.prod.nesistel
#
# Consumer: `compose.staging.yaml` + HAProxy same-origin
# Guide:    docs/deploy/haproxy-same-origin.md
#
# Staging = public preview / QA on a VPS (e.g. nesisstel network),
# NOT local development and NOT final production.
#
# Never commit real passwords. Generate SESSION_SECRET per environment:
#   openssl rand -base64 48

# Runtime
NODE_ENV=production
HOST=0.0.0.0
PORT=3000
LOG_LEVEL=info

# Postgres (Compose service `postgres` on the staging network)
POSTGRES_DB=tador_staging
POSTGRES_USER=tador_stg
POSTGRES_PASSWORD=REPLACE_WITH_STAGING_DB_PASSWORD
# Not published to the public internet; used only inside Compose.
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Prefer an explicit URL for Prisma / Fastify (host = Compose DNS name).
DATABASE_URL=postgresql://tador_stg:REPLACE_WITH_STAGING_DB_PASSWORD@postgres:5432/tador_staging

# Session + CORS (must match the public HTTPS origin behind HAProxy)
SESSION_SECRET=REPLACE_WITH_AT_LEAST_32_RANDOM_BYTES
CORS_ORIGIN=https://tador.example.tel

# Feature gates
ENABLE_PLANTILLAS_ADMIN=false
REQUIRE_EMAIL_VERIFICATION=false

# Loopback publish for HAProxy on the same host (Compose interpolation)
BACKEND_HOST_PORT=3000
FRONTEND_HOST_PORT=8080

# Optional post-MVP (backend does not consume these yet)
# APP_PUBLIC_URL=https://tador.example.tel
# EMAIL_PROVIDER=smtp
# EMAIL_FROM=noreply@tador.example.tel
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
