# Host Prisma / local Node (not Docker Compose)
# Copy: cp .env.example .env
#
# For day-to-day app use prefer root `.env` + `docker compose up`.
# This file is for Prisma CLI or Fastify started on the host against
# published Postgres (localhost:5432).

DATABASE_URL=postgresql://tador:tador_dev_password@localhost:5432/tador_dev
SESSION_SECRET=change-me-in-production
# Comma-separated browser origins allowed with credentials (SPA).
CORS_ORIGIN=http://localhost:5173
PORT=3000
HOST=0.0.0.0

# Integration tests use .env.test (see .env.test.example) — never tador_dev.
