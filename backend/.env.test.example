# Vitest integration only — never use tador_dev here.
# Copy to .env.test and adjust. CI can set DATABASE_URL instead (wins over this file).
#
# Prefer pieces (host auto: Docker → postgres, host machine → localhost).
# For a remote test server, set DATABASE_URL to that server's test database.

POSTGRES_USER=tador
POSTGRES_PASSWORD=tador_dev_password
POSTGRES_TEST_DB=tador_test
# POSTGRES_HOST=postgres
# POSTGRES_PORT=5432

# Optional full URL (must end with /tador_test or POSTGRES_TEST_DB name):
# DATABASE_URL=postgresql://tador:tador_dev_password@postgres:5432/tador_test

SESSION_SECRET=test-secret-for-integration-tests
