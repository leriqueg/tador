# Integration tests only. Never point these values at development or production.
# Host is auto-detected: Docker uses postgres; the host machine uses localhost.
POSTGRES_USER=tador
POSTGRES_PASSWORD=tador_dev_password
POSTGRES_TEST_DB=tador_test
SESSION_SECRET=test-secret-for-integration-tests

# Optional: use a dedicated remote/ephemeral test database instead.
# DATABASE_URL=postgresql://tador:password@test-db.example.com:5432/tador_test
