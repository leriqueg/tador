{
  "name": "tador-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "vitest run --config vitest.integration.config.ts",
    "test:watch": "vitest run --config vitest.integration.config.ts --watch",
    "test:unit": "vitest run --config vitest.unit.config.ts",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "db:migrate": "node scripts/run-with-db-url.mjs npx prisma migrate dev",
    "db:migrate:deploy": "node scripts/run-with-db-url.mjs npx prisma migrate deploy",
    "db:generate": "prisma generate",
    "db:studio": "node scripts/run-with-db-url.mjs npx prisma studio",
    "seed:catalogos": "node scripts/run-with-db-url.mjs npx tsx prisma/seed/catalogos.ts",
    "migrate:test20260719": "node scripts/run-with-db-url.mjs npx tsx scripts/migrate/test20260719/run.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.0",
    "@prisma/client": "^6.0.0",
    "argon2": "^0.41.0",
    "decimal.js": "^10.4.3",
    "fastify": "^5.0.0",
    "nanoid": "^5.0.0",
    "pino": "^9.0.0",
    "pino-pretty": "^13.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "dotenv": "^16.6.1",
    "prisma": "^6.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
