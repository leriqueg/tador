generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TipoCuenta {
  bank
  card
  wallet
  bridge
  incomeCategory
  expenseCategory

  @@map("tipo_cuenta")
}

enum TipoEntidad {
  person
  organization
  bank
  issuer

  @@map("tipo_entidad")
}

enum AsientoTipo {
  manual
  reversa

  @@map("asiento_tipo")
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  verifiedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  books            Book[]
  sessions         Session[]
  cuentasUsuario   CuentaUsuario[]
  entidades        Entidad[]
  tags             Tag[]
  activaciones     ActivacionCuentaGlobal[]

  @@map("users")
}

model Book {
  id        String   @id @default(cuid())
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  config    BookConfig?
  asientos  Asiento[]
  periodos  PeriodoContable[]

  @@map("books")
}

model BookConfig {
  id             String   @id @default(cuid())
  bookId         String   @unique
  currency       String   @default("USD")
  locale         String   @default("en-US")
  format         String   @default("symbol")
  currencyLocked Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@map("book_configs")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model CuentaGlobal {
  id          String   @id @default(cuid())
  parentId    String?
  codigo      String   @unique
  nombre      String
  descripcion String   @default("")
  esPostable  Boolean  @default(false)
  legacyId    Int?
  legacyCode  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  parent          CuentaGlobal?            @relation("GlobalAccountHierarchy", fields: [parentId], references: [id])
  children        CuentaGlobal[]            @relation("GlobalAccountHierarchy")
  cuentasUsuario  CuentaUsuario[]
  activaciones    ActivacionCuentaGlobal[]
  lineas          LineaAsiento[]

  @@map("cuentas_globales")
}

model CuentaUsuario {
  id                 String     @id @default(cuid())
  userId             String
  codigo             String?
  globalId           String?
  entidadId          String?
  tipoCuenta         TipoCuenta
  nombre             String
  codigoPersonalizado String?
  activa             Boolean    @default(true)
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  user    User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  global  CuentaGlobal?   @relation(fields: [globalId], references: [id])
  entidad Entidad?        @relation(fields: [entidadId], references: [id])
  lineas  LineaAsiento[]

  @@unique([userId, codigo])
  @@map("cuentas_usuario")
}

model Entidad {
  id        String      @id @default(cuid())
  userId    String
  nombre    String
  tipo      TipoEntidad
  notas     String?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  cuentasUsuario CuentaUsuario[]

  @@unique([userId, nombre])
  @@map("entidades")
}

model Tag {
  id        String   @id @default(cuid())
  userId    String
  nombre    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, nombre])
  @@map("tags")
}

model ActivacionCuentaGlobal {
  id             String   @id @default(cuid())
  userId         String
  globalId       String
  activa         Boolean  @default(true)
  nombreOverride String?
  createdAt      DateTime @default(now())

  user   User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  global CuentaGlobal @relation(fields: [globalId], references: [id])

  @@unique([userId, globalId])
  @@map("activaciones_cuenta_global")
}

model Asiento {
  id                String     @id @default(cuid())
  bookId            String
  fecha             DateTime
  concepto          String
  tipo              AsientoTipo
  asientoOriginalId String?
  idempotencyKey    String?    @unique
  anulado           Boolean    @default(false)
  anuladoAt         DateTime?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  book            Book            @relation(fields: [bookId], references: [id], onDelete: Cascade)
  asientoOriginal Asiento?        @relation("Reversa", fields: [asientoOriginalId], references: [id])
  reversos        Asiento[]       @relation("Reversa")
  lineas          LineaAsiento[]
  versiones       AsientoVersion[]

  @@map("asientos")
}

model LineaAsiento {
  id             String         @id @default(cuid())
  asientoId      String
  cuentaId       String?
  cuentaGlobalId String?
  debito         Decimal        @default(0)
  credito        Decimal        @default(0)
  createdAt      DateTime       @default(now())

  asiento      Asiento        @relation(fields: [asientoId], references: [id], onDelete: Cascade)
  cuenta       CuentaUsuario? @relation(fields: [cuentaId], references: [id])
  cuentaGlobal CuentaGlobal?  @relation(fields: [cuentaGlobalId], references: [id])

  @@map("lineas_asiento")
}

model AsientoVersion {
  id         String   @id @default(cuid())
  asientoId  String
  version    Int
  snapshot   Json
  modifiedBy String
  createdAt  DateTime @default(now())

  asiento Asiento @relation(fields: [asientoId], references: [id], onDelete: Cascade)

  @@map("asiento_versions")
}

model PeriodoContable {
  id          String    @id @default(cuid())
  bookId      String
  año         Int
  abierto     Boolean   @default(true)
  cerradoAt   DateTime?
  reabiertoAt DateTime?
  createdAt   DateTime  @default(now())

  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([bookId, año])
  @@map("periodos_contables")
}
